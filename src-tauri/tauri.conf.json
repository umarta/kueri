{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kueri",
  "version": "0.5.0",
  "identifier": "dev.kueri.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kueri",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
